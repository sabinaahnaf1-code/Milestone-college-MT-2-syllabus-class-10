rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: progress
    // Document ID: {uid}_{subject}_{chapter} (or auto-id)
    // Fields:
    //   - uid: string (required) - The user's ID
    //   - subject: string (required) - Subject name
    //   - chapter: string (required) - Chapter identifier
    //   - completed: boolean (required) - Completion status
    //   - updatedAt: timestamp (required) - Last update time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['uid', 'subject', 'chapter', 'completed', 'updatedAt']) &&
             data.uid is string &&
             data.subject is string &&
             data.chapter is string &&
             data.completed is bool &&
             data.updatedAt is timestamp;
    }

    match /progress/{progressId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      isValidProgress(request.resource.data);
      allow update: if isAuthenticated() && 
                      resource.data.uid == request.auth.uid &&
                      request.resource.data.uid == request.auth.uid &&
                      isValidProgress(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
