rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: progress
    // Document ID: {uid}_{subject}_{chapter}
    // Fields:
    //   - uid: string (required) - The user's ID (Firebase UID or simple_username)
    //   - subject: string (required) - Subject name
    //   - chapter: string (required) - Chapter identifier
    //   - completed: boolean (required) - Completion status
    //   - updatedAt: timestamp (required) - Last update time
    //
    // Collection: simple_users
    // Document ID: simple_{username}
    // Fields:
    //   - username: string
    //   - pin: string (4 digits)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSimpleUser(uid) {
      return uid.startsWith('simple_');
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['uid', 'subject', 'chapter', 'completed', 'updatedAt']) &&
             data.uid is string &&
             data.subject is string &&
             data.chapter is string &&
             data.completed is bool &&
             (data.updatedAt is timestamp || data.updatedAt == null);
    }

    match /simple_users/{userId} {
      allow read, write: if true; // Low security for "any username" simple auth as requested
    }

    match /progress/{progressId} {
      allow read: if (isAuthenticated() && resource.data.uid == request.auth.uid) || 
                     isSimpleUser(resource.data.uid);
      allow create, update, delete: if (isAuthenticated() && request.resource.data.uid == request.auth.uid) || 
                                      isSimpleUser(request.resource.data.uid);
    }
  }
}
